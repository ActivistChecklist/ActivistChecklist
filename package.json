{
  "name": "activistchecklist",
  "version": "1.0.0",
  "description": "ActivistChecklist.org",
  "license": "GPL-3.0",
  "private": true,
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "prepare": "node scripts/prepare.js",
    "install:ci": "pnpm install --frozen-lockfile --prefer-offline --fetch-timeout 100000",
    "start": "next start",
    "clean": "rm -rf .next build node_modules out && pnpm store prune && pnpm install",
    "dev": "concurrently -n \"API,NEXT\" -c \"blue,green\" \"NODE_NO_WARNINGS=1 pnpm api:dev\" \"pnpm next:dev\"",
    "next:dev": "next dev --turbopack",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint:paths": "node scripts/trailing-slash-paths.mjs --check",
    "fix:paths": "node scripts/trailing-slash-paths.mjs --fix",
    "fetch-news": "node scripts/fetch-news-images.js",
    "fetch:eol": "node scripts/fetch-endoflife-snapshot.mjs",
    "news": "node scripts/news-wizard.js",
    "metadata": "node scripts/metadata-cli.cjs",
    "keystatic:format-mdx": "node scripts/keystatic-format-mdx.mjs",
    "crowdin:hide-strings": "node scripts/crowdin-hide-strings.mjs",
    "crowdin:hide-strings:apply": "node scripts/crowdin-hide-strings.mjs --apply",
    "crowdin:pre-translate": "node scripts/crowdin-pre-translate.mjs",
    "crowdin:translation-status": "node scripts/crowdin-translation-status.mjs",
    "prebuild": "(pnpm audit --audit-level high || true) && (pnpm fetch:eol || true)",
    "build": "NEXT_TELEMETRY_DISABLED=1 next build",
    "buildstatic": "BUILD_MODE=static pnpm build && pnpm check-build && pnpm check-links && pnpm validate-build",
    "postbuild": "bash scripts/postbuild.sh",
    "og-images": "node scripts/generate-og-images.mjs",
    "og-images:clean": "node scripts/generate-og-images.mjs --clean",
    "index": "NODE_ENV=${NODE_ENV} bash scripts/build-search-index.sh",
    "rss": "node scripts/generate-rss.mjs",
    "llms-txt": "node scripts/build-llms-txt.cjs",
    "seo:audit": "node scripts/seo-audit.cjs",
    "seo:audit:strict": "node scripts/seo-audit.cjs --strict",
    "buildbackup": "node scripts/build-backup.mjs",
    "check-links": "node scripts/check-links.mjs",
    "healthcheck-ssl": "bash scripts/healthcheck-ssl.sh",
    "healthcheck-domain": "bash scripts/healthcheck-domain.sh",
    "healthcheck-api": "bash scripts/healthcheck-api.sh",
    "check-build": "node scripts/check-build.mjs",
    "validate-build": "node scripts/validate-build.mjs",
    "canary": "node scripts/canary.mjs",
    "serve": "npx serve out",
    "deploy": "bash scripts/deploy.sh",
    "deploy:remote": "bash scripts/deploy-remote.sh",
    "deploy:assets": "bash scripts/deploy-assets.sh",
    "deploy:secrets": "bash scripts/deploy-secrets.sh",
    "snapshot": "node scripts/snapshot.mjs",
    "snapshot-normalize": "node scripts/snapshot-normalize.mjs",
    "snapshot-compare": "node scripts/snapshot-compare.mjs",
    "compare": "node scripts/compare.mjs",
    "annotations:cleanup": "tsx scripts/annotations-cleanup.mjs",
    "annotations:init": "tsx scripts/annotations-init.mjs",
    "rrc:link": "node scripts/rrc-link.mjs link",
    "rrc:unlink": "node scripts/rrc-link.mjs unlink",
    "rrc:status": "node scripts/rrc-link.mjs status",
    "api:dev": "source .env && fastify start --options --watch --ignore-watch '.git node_modules out .next content public scripts utils styles pages config compontents' --log-level info --pretty-logs --port ${API_PORT:-4321} api/server.js",
    "api:start": "pnpm exec pm2 start ecosystem.config.js",
    "api:stop": "pnpm exec pm2 stop ac-api",
    "api:restart": "pnpm exec pm2 restart ac-api",
    "api:status": "pnpm exec pm2 status ac-api",
    "api:delete": "pnpm exec pm2 delete ac-api",
    "api:logs": "pnpm exec pm2 logs ac-api",
    "mongo:start": "sh -c 'docker start ac-mongo >/dev/null 2>&1 || docker run -d --name ac-mongo -p 27017:27017 -v ac-mongo-data:/data/db mongo:7'"
  },
  "dependencies": {
    "@activistchecklist/react-review-comments": "^0.3.0",
    "@activistchecklist/umami-extra-privacy": "github:ActivistChecklist/umami-extra-privacy#7669154d772ecbf3410c1243e8014ac8a0e74c5e",
    "@fastify/cors": "^11.3.0",
    "@fastify/helmet": "^13.1.0",
    "@fastify/rate-limit": "^11.1.0",
    "@hookform/resolvers": "^5.4.0",
    "@keystatic/core": "^0.5.51",
    "@keystatic/next": "^5.0.4",
    "@next/env": "^16.2.10",
    "@radix-ui/react-accordion": "^1.2.16",
    "@radix-ui/react-alert-dialog": "^1.1.19",
    "@radix-ui/react-aspect-ratio": "^1.1.11",
    "@radix-ui/react-checkbox": "^1.3.7",
    "@radix-ui/react-collapsible": "^1.1.16",
    "@radix-ui/react-context-menu": "^2.3.3",
    "@radix-ui/react-dialog": "^1.1.19",
    "@radix-ui/react-dropdown-menu": "^2.1.20",
    "@radix-ui/react-hover-card": "^1.1.19",
    "@radix-ui/react-label": "^2.1.11",
    "@radix-ui/react-menubar": "^1.1.20",
    "@radix-ui/react-navigation-menu": "^1.2.18",
    "@radix-ui/react-popover": "^1.1.19",
    "@radix-ui/react-radio-group": "^1.4.3",
    "@radix-ui/react-select": "^2.3.3",
    "@radix-ui/react-separator": "^1.1.11",
    "@radix-ui/react-slot": "1.3.0",
    "@radix-ui/react-switch": "^1.3.3",
    "@radix-ui/react-tabs": "^1.1.17",
    "@radix-ui/react-toggle": "^1.1.14",
    "@radix-ui/react-toggle-group": "^1.1.15",
    "@radix-ui/react-tooltip": "^1.2.12",
    "@recogito/text-annotator": "^4.2.5",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "dotenv": "^17.4.2",
    "fastify": "^5.10.0",
    "fluent-ffmpeg": "^2.1.3",
    "fuse.js": "^7.5.0",
    "gray-matter": "^4.0.3",
    "js-yaml": "^4.3.0",
    "lucide-react": "^1.24.0",
    "mongodb": "^7.5.0",
    "next": "^15.5.20",
    "next-intl": "^4.13.2",
    "next-mdx-remote": "^6.0.0",
    "next-themes": "^0.4.6",
    "openpgp": "^6.3.1",
    "openseadragon": "^6.0.2",
    "pdf-lib": "^1.17.1",
    "pm2": "^7.0.3",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-hook-form": "^7.81.0",
    "react-icons": "^5.7.0",
    "react-intersection-observer": "^10.1.0",
    "rehype-sanitize": "^6.0.0",
    "remark": "^15.0.1",
    "remark-gfm": "^4.0.1",
    "remark-html": "^16.0.1",
    "remark-parse": "^11.0.0",
    "server-only": "^0.0.1",
    "tailwind-merge": "^3.6.0",
    "tailwindcss-animate": "^1.0.7",
    "unified": "^11.0.5",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.3.2",
    "@types/node": "25.9.2",
    "@types/react": "19.2.17",
    "add": "^2.0.6",
    "chalk": "^5.6.2",
    "cheerio": "^1.2.0",
    "commander": "^15.0.0",
    "concurrently": "^10.0.3",
    "fastify-cli": "^8.0.0",
    "feed": "^5.2.1",
    "http-server": "^14.1.1",
    "husky": "^9.1.7",
    "jsdom": "^29.1.1",
    "next-sitemap": "^4.2.3",
    "node-fetch": "^3.3.2",
    "open-graph-scraper": "^6.12.0",
    "pagefind": "^1.5.2",
    "postcss": "^8.5.19",
    "prettier": "^3.9.5",
    "react-json-view": "^1.21.3",
    "rss-parser": "^3.13.0",
    "satori": "^0.26.0",
    "sharp": "^0.35.3",
    "tailwindcss": "^4.3.2",
    "tsx": "^4.23.1",
    "typescript": "6.0.3",
    "vite": "^8.1.4",
    "vitest": "^4.1.10"
  },
  "packageManager": "pnpm@11.4.0+sha512.f0febc7e37552ab485494a914241b338e0b3580b93d54ce31f00933015880863129038a1b4ae4e414a0ee63ac35bf21197e990172c4a68256450b5636310968f"
}
